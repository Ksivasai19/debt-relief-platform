# Copy this file to .env and fill in your own values

# Get a free key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AQ.Ab8RN6LtA_qufHgIZH-y_PKA3Zs9WzLBy4fpMnN6MOrDuVABeA

# Secret used to sign JWT auth tokens - change this to a long random string
JWT_SECRET_KEY=change_this_to_a_long_random_secret_string

# Access token expiry in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# SQLite database file (relative to backend/ directory)
DATABASE_URL=sqlite:///./debt_relief.db

# Comma-separated list of allowed frontend origins for CORS
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
